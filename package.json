{
  "name": "pawn-electron",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "commitlint": "commitlint --edit",
    "start": "concurrently -k \"npm run api:dev\" \"npm run dev\"",
    "dev": "vite",
    "devdb": "v",
    "mobile:start": "npm --prefnpm run electron:deix mobile-react-native start",
    "android": "npm --prefix mobile-react-native run android",
    "ios": "npm --prefix mobile-react-native run ios",
    "web": "npm --prefix mobile-react-native run web",
    "build": "tsc -b && vite build",
    "api:dev": "tsx server/src/index.ts",
    "api:seed": "tsx server/src/seed.ts",
    "api:build": "rm -rf dist-server && tsc -p tsconfig.server.json",
    "api:start": "node dist-server/server/src/index.js",
    "test:unit": "tsx --test shared/**/*.test.ts",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "npm run build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:start": "wait-on tcp:5173 tcp:8787 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "rebuild": "electron-builder install-app-deps",
    "electron:dev": "concurrently -k \"npm run docker:up\" \"cross-env BROWSER=none npm run dev\" \"npm run electron:start\" \"tsc -w -p tsconfig.electron.json\" \"tsc -w -p tsconfig.preload.json\""
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-myanmar": "^5.2.7",
    "@vladmandic/face-api": "^1.7.15",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "html5-qrcode": "^2.3.8",
    "i18next": "^26.0.8",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.8",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
