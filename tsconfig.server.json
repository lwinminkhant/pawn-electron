{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2022",
    "moduleResolution": "nodenext",
    "rootDir": ".",
    "outDir": "dist-server",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["server/src/**/*", "shared/**/*"],
  "exclude": ["**/*.test.ts"]
}
